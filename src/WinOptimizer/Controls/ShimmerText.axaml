             xmlns:controls="using:WinOptimizer.Controls"
             x:Class="WinOptimizer.Controls.ShimmerText"
             x:DataType="controls:ShimmerText"
             IsHitTestVisible="True">
    <Canvas Name="TextCanvas" ClipToBounds="False" />
</UserControl>
