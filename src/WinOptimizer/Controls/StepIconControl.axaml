<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:WinOptimizer.Controls"
             x:Class="WinOptimizer.Controls.StepIconControl"
             x:DataType="controls:StepIconControl"
             Width="120" Height="120">

    <Grid>
        <!-- CreatingRestorePoint: Shield with checkmark -->
        <Path Name="IconRestorePoint" Opacity="0"
              Fill="White"
              Stretch="Uniform" Width="80" Height="80"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M10,17L6,13L7.41,11.59L10,14.17L16.59,7.58L18,9L10,17Z">
            <Path.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Path.RenderTransform>
        </Path>

        <!-- SystemScan: Magnifying glass -->
        <Path Name="IconSystemScan" Opacity="0"
              Fill="White"
              Stretch="Uniform" Width="80" Height="80"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              Data="M15.5,14H14.71L14.43,13.73C15.41,12.59 16,11.11 16,9.5C16,5.91 13.09,3 9.5,3C5.91,3 3,5.91 3,9.5C3,13.09 5.91,16 9.5,16C11.11,16 12.59,15.41 13.73,14.43L14,14.71V15.5L19,20.49L20.49,19L15.5,14M9.5,14C7.01,14 5,11.99 5,9.5C5,7.01 7.01,5 9.5,5C11.99,5 14,7.01 14,9.5C14,11.99 11.99,14 9.5,14Z">
            <Path.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Path.RenderTransform>
        </Path>

