              Stretch="Uniform" Width="80" Height="80"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.95C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.95L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z">
            <Path.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Path.RenderTransform>
        </Path>

        <!-- StartupOptimize: Rocket -->
        <Path Name="IconStartupOptimize" Opacity="0"
              Fill="White"
              Stretch="Uniform" Width="80" Height="80"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M16.2,16.2L6,10L16.2,6L10,16.2L12,12L16.2,16.2Z">
            <Path.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Path.RenderTransform>
        </Path>

        <!-- DriverUpdate: Wrench -->
        <Path Name="IconDriverUpdate" Opacity="0"
              Fill="White"
              Stretch="Uniform" Width="80" Height="80"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              Data="M22.7,19L13.6,9.9C14.5,7.6 14,4.9 12.1,3C10.1,1 7.1,0.6 4.7,1.7L9,6L6,9L1.6,4.7C0.4,7.1 0.9,10.1 2.9,12.1C4.8,14 7.5,14.5 9.8,13.6L18.9,22.7C19.3,23.1 19.9,23.1 20.3,22.7L22.6,20.4C23.1,20 23.1,19.3 22.7,19Z">
            <Path.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Path.RenderTransform>
        </Path>

        <!-- Completed: Checkmark -->
        <Path Name="IconCompleted" Opacity="0"
              Fill="#1B5E20"
              Stretch="Uniform" Width="80" Height="80"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              Data="M12,2C6.48,2 2,6.48 2,12C2,17.52 6.48,22 12,22C17.52,22 22,17.52 22,12C22,6.48 17.52,2 12,2M10,17L5,12L6.41,10.59L10,14.17L17.59,6.58L19,8L10,17Z">
            <Path.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Path.RenderTransform>
        </Path>

        <!-- Error: X mark -->
        <Path Name="IconError" Opacity="0"
              Fill="#B71C1C"
              Stretch="Uniform" Width="80" Height="80"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              Data="M12,2C6.47,2 2,6.47 2,12C2,17.53 6.47,22 12,22C17.53,22 22,17.53 22,12C22,6.47 17.53,2 12,2M15.59,17L12,13.41L8.41,17L7,15.59L10.59,12L7,8.41L8.41,7L12,10.59L15.59,7L17,8.41L13.41,12L17,15.59L15.59,17Z">
            <Path.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Path.RenderTransform>
        </Path>
    </Grid>

</UserControl>
