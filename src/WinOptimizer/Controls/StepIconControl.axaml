              Stretch="Uniform" Width="80" Height="80"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              Data="M20,8H17.19C16.74,7.22 16.12,6.55 15.37,6.04L17,4.41L15.59,3L13.42,5.17C12.96,5.06 12.49,5 12,5C11.51,5 11.04,5.06 10.59,5.17L8.41,3L7,4.41L8.62,6.04C7.88,6.55 7.26,7.22 6.81,8H4V10H6.09C6.04,10.33 6,10.66 6,11V12H4V14H6V15C6,15.34 6.04,15.67 6.09,16H4V18H6.81C7.85,19.79 9.78,21 12,21C14.22,21 16.15,19.79 17.19,18H20V16H17.91C17.96,15.67 18,15.34 18,15V14H20V12H18V11C18,10.66 17.96,10.33 17.91,10H20V8M14,16H10V14H14V16M14,12H10V10H14V12Z">
            <Path.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Path.RenderTransform>
        </Path>

        <!-- ProgramRemoval: Delete/Uninstall -->
        <Path Name="IconProgramRemoval" Opacity="0"
              Fill="White"
              Stretch="Uniform" Width="80" Height="80"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              Data="M6,19C6,20.1 6.9,21 8,21H16C17.1,21 18,20.1 18,19V7H6V19M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4Z">
            <Path.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Path.RenderTransform>
        </Path>

        <!-- DiskCleanup: Broom -->
        <Path Name="IconDiskCleanup" Opacity="0"
              Fill="White"
              Stretch="Uniform" Width="80" Height="80"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              Data="M19.36,2.72L20.78,4.14L15.06,9.85C16.13,11.39 16.28,13.24 15.38,14.44L9.06,8.12C10.26,7.22 12.11,7.37 13.65,8.44L19.36,2.72M5.93,17.57C3.92,15.56 2.69,13.16 2.35,10.92L7.23,8.83L14.67,16.27L12.58,21.15C10.34,20.81 7.94,19.58 5.93,17.57Z">
            <Path.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Path.RenderTransform>
        </Path>

        <!-- DiskOptimize: HDD -->
        <Path Name="IconDiskOptimize" Opacity="0"
              Fill="White"
              Stretch="Uniform" Width="80" Height="80"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              Data="M6,2H18A2,2 0 0,1 20,4V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V4A2,2 0 0,1 6,2M12,4A6,6 0 0,0 6,10C6,13.31 8.69,16 12,16A6,6 0 0,0 18,10A6,6 0 0,0 12,4M12,6A4,4 0 0,1 16,10A4,4 0 0,1 12,14A4,4 0 0,1 8,10A4,4 0 0,1 12,6M12,8A2,2 0 0,0 10,10A2,2 0 0,0 12,12A2,2 0 0,0 14,10A2,2 0 0,0 12,8M12,18A1,1 0 0,0 11,19A1,1 0 0,0 12,20A1,1 0 0,0 13,19A1,1 0 0,0 12,18Z">
            <Path.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Path.RenderTransform>
        </Path>

