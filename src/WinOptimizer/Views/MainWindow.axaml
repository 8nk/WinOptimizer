<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WinOptimizer.ViewModels"
        xmlns:controls="using:WinOptimizer.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="550"
        x:Class="WinOptimizer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/winoptimizer.ico"
        Title="WinFlow Installer"
        Width="800"
        Height="550"
        CanResize="False">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- Override Fluent theme button foreground for gradient buttons -->
    <Window.Styles>
        <Style Selector="Button.accentButton /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.accentButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.accentButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>

    <Grid>
        <!-- ========== SCREEN 0: ACTIVATION ========== -->
        <Grid IsVisible="{Binding ShowActivationScreen}" ClipToBounds="True">
            <controls:AnimatedGradientBackground Palette="cyan" />
            <controls:FloatingBubbles />

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" MaxWidth="400">
                <controls:ShimmerText DisplayText="WinFlow Installer"
                                      TextSize="38"
                                      BaseColor="#006064"
                                      ShimmerColor="#4DD0E1"
                                      Width="380" Height="55"
                                      HorizontalAlignment="Center"/>

                <TextBlock Text="Activation"
                           FontSize="16"
                           Foreground="#00ACC1"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <Border Background="#C0FFFFFF"
                        CornerRadius="16"
                        Padding="28,24"
                        BoxShadow="0 4 20 0 #20000000">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Enter activation code:"
                                   FontSize="14"
                                   Foreground="#37474F"/>

                        <TextBox x:Name="ActivationCodeBox"
                                 Text="{Binding ActivationCode, Mode=TwoWay}"
                                 Watermark="00-00-00-00-00-00"
                                 MaxLength="17"
                                 FontSize="18"
                                 FontFamily="Consolas"
                                 Height="48"
                                 CornerRadius="8"
                                 LetterSpacing="2"
                                 TextChanged="ActivationCodeBox_TextChanged"/>

                        <TextBlock Text="{Binding ActivationStatus}"
                                   FontSize="13"
                                   Foreground="{Binding ActivationStatusBrush}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding HasActivationStatus}"/>

                        <Button Content="{Binding ActivateButtonText}"
                                Command="{Binding ActivateCommand}"
                                IsEnabled="{Binding CanActivate}"
                                Height="48"
                                FontSize="16"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                CornerRadius="8"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ========== SCREEN 1: LANGUAGE SELECT ========== -->
        <Grid IsVisible="{Binding ShowLanguageScreen}" Margin="30">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <TextBlock Text="WinFlow Installer"
                           FontSize="42"
                           FontWeight="Bold"
                           Foreground="#006064"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Select language / Оберіть мову / Выберите язык"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Foreground="Gray"
                           Margin="0,10,0,20"/>

                <Button Content="English"
                        Command="{Binding SelectLanguageCommand}"
                        CommandParameter="en"
                        Height="50" Width="300"
                        FontSize="16"
                        HorizontalContentAlignment="Center"/>

                <Button Content="Українська"
                        Command="{Binding SelectLanguageCommand}"
                        CommandParameter="uk"
                        Height="50" Width="300"
                        FontSize="16"
                        HorizontalContentAlignment="Center"/>

                <Button Content="Русский"
                        Command="{Binding SelectLanguageCommand}"
                        CommandParameter="ru"
                        Height="50" Width="300"
                        FontSize="16"
                        HorizontalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ========== SCREEN 2: SYSTEM ANALYSIS + 2 BUTTONS (NOT FULLSCREEN) ========== -->
        <Grid IsVisible="{Binding ShowMainScreen}" ClipToBounds="True">
            <controls:AnimatedGradientBackground Palette="deep" />
            <controls:FloatingBubbles />

            <Grid MaxWidth="700" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="4" Margin="0,0,0,16">
                    <controls:ShimmerText DisplayText="WinFlow Installer"
                                          TextSize="34"
                                          BaseColor="#B2EBF2"
                                          ShimmerColor="#FFFFFF"
                                          Width="340" Height="48"
                                          HorizontalAlignment="Center"/>

                    <TextBlock Text="{Binding SubtitleText}"
                               FontSize="15"
                               HorizontalAlignment="Center"
                               Foreground="#B2EBF2"/>
                </StackPanel>

                <!-- System Info Card -->
                <Border Grid.Row="1"
                        Background="#B0FFFFFF"
                        CornerRadius="16"
                        Padding="24,18"
                        BoxShadow="0 4 20 0 #20000000"
                        Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Hardware info -->
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="{Binding SystemInfoLabel}"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Foreground="#006064"/>

                            <TextBlock Text="{Binding SystemInfoText}"
                                       TextWrapping="Wrap"
                                       FontSize="13"
                                       Foreground="#37474F"
                                       LineHeight="20"/>

                            <TextBlock Text="{Binding CurrentOsText}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#006064"
                                       Margin="0,4,0,0"/>

                            <!-- HWID -->
                            <TextBlock Text="{Binding HwidText}"
                                       FontSize="12"
                                       FontFamily="Consolas"
                                       Foreground="#78909C"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Right: Recommendation -->
                        <Border Grid.Column="1"
                                Background="#E0F7FA"
                                CornerRadius="12"
                                Padding="18,14"
                                Margin="16,0,0,0"
                                MinWidth="200"
                                IsVisible="{Binding HasHardwareInfo}"
                                VerticalAlignment="Center">
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <TextBlock Text="&#x1F4BB;"
                                           FontSize="28"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding RecommendedWindowsText}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#004D40"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding RecommendationReason}"
                                           FontSize="11"
                                           Foreground="#4DB6AC"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           MaxWidth="180"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Status -->
                <TextBlock Grid.Row="2"
                           Text="{Binding StatusMessage}"
                           HorizontalAlignment="Center"
                           FontSize="14"
                           Foreground="#B2EBF2"
                           Margin="0,0,0,12"/>

                <!-- Install button -->
                <Button Grid.Row="3"
                        Command="{Binding AutoInstallCommand}"
                        IsEnabled="{Binding CanStart}"
                        Height="72"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        CornerRadius="14"
                        Margin="0,0,0,12"
                        Classes="accentButton">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                            <GradientStop Color="#00897B" Offset="0"/>
                            <GradientStop Color="#00ACC1" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="&#x1F680;"
                                   FontSize="20"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding AutoInstallButtonText}"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Bottom hint -->
                <TextBlock Grid.Row="4"
                           Text="{Binding BottomHintText}"
                           FontSize="12"
                           Foreground="#80FFFFFF"
                           HorizontalAlignment="Center"/>
            </Grid>

        </Grid>

        <!-- ========== SCREEN 3: INSTALLING ========== -->
        <Grid IsVisible="{Binding IsOptimizing}" ClipToBounds="True">
            <controls:AnimatedGradientBackground Palette="auto" />
            <controls:FloatingBubbles />

            <!-- ═══ PHASE 1: FULLSCREEN LAYOUT (кроки 1-8) ═══ -->
            <Grid IsVisible="{Binding !IsPhase2}" MaxWidth="900" HorizontalAlignment="Center" Margin="60,30,60,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <controls:ShimmerText Grid.Row="0"
                                      DisplayText="WinFlow Installer"
                                      TextSize="22"
                                      BaseColor="#80FFFFFF"
                                      ShimmerColor="#FFFFFF"
                                      Width="220" Height="34"
                                      HorizontalAlignment="Center"
                                      Margin="0,10,0,0"/>

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="12">

                    <!-- Big circular progress -->
                    <Grid Width="200" Height="200" HorizontalAlignment="Center">
                        <controls:GlowPulseEffect GlowColor="#00BCD4"
                                                   Width="200" Height="200"
                                                   IsVisible="{Binding !IsCompleted}"/>
                        <controls:CircularProgressControl Progress="{Binding ProgressPercent}"
                                                           RingThickness="10"
                                                           Width="190" Height="190"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding ShowPercentage}"/>
                        <controls:StepIconControl CurrentStep="{Binding CurrentOptimizationStep}"
                                                  Width="130" Height="130"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  IsVisible="{Binding !ShowPercentage}"/>
                    </Grid>

                    <!-- Big status text -->
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               TextAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="12" Color="#000000" Opacity="0.3" OffsetX="0" OffsetY="2"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="10" Margin="0,0,0,16">
                    <controls:ProgressDotsControl CurrentStepIndex="{Binding CurrentStepIndex}"
                                                  HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding StepDescription}"
                               FontSize="20"
                               Foreground="#DDFFFFFF"
                               HorizontalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="8" Color="#000000" Opacity="0.15" OffsetX="0" OffsetY="1"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Row="3"
                        Background="#B0FFFFFF"
                        CornerRadius="16"
                        Padding="28,14"
                        Margin="0,0,0,12"
                        MinHeight="50"
                        MaxHeight="250">
                    <ScrollViewer x:Name="LogScrollViewer"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding LogEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:LogEntry">
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,3"
                                                Opacity="{Binding Opacity}">
                                        <StackPanel.Transitions>
                                            <Transitions>
                                                <DoubleTransition Property="Opacity" Duration="0:0:0.6"/>
                                            </Transitions>
                                        </StackPanel.Transitions>
                                        <TextBlock Text="{Binding Icon}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Width="18"
                                                   Foreground="{Binding IconBrush}"/>
                                        <TextBlock Text="{Binding Text}"
                                                   FontSize="14"
                                                   Foreground="#37474F"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <StackPanel Grid.Row="4" HorizontalAlignment="Center" Spacing="4">
                    <TextBlock Text="{Binding BottomHintText}"
                               FontSize="18"
                               Foreground="#BBFFFFFF"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding HwidText}"
                               FontSize="11"
                               FontFamily="Consolas"
                               Foreground="#66FFFFFF"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,6"/>
                </StackPanel>
            </Grid>

            <!-- ═══ PHASE 2: COMPACT WINDOWED LAYOUT 800×500 (кроки 9+) ═══ -->
            <Grid IsVisible="{Binding IsPhase2}" Margin="28,14,28,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <controls:ShimmerText Grid.Row="0"
                                      DisplayText="WinFlow Installer"
                                      TextSize="16"
                                      BaseColor="#80FFFFFF"
                                      ShimmerColor="#FFFFFF"
                                      Width="160" Height="24"
                                      HorizontalAlignment="Center"
                                      Margin="0,2,0,6"/>

                <!-- Phase 2 success header -->
                <TextBlock Grid.Row="1"
                           Text="{Binding Phase2HeaderText}"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,0,0,10">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="10" Color="#000000" Opacity="0.25" OffsetX="0" OffsetY="2"/>
                    </TextBlock.Effect>
                </TextBlock>

                <!-- Step dots + description -->
                <StackPanel Grid.Row="2" Spacing="4" Margin="0,0,0,8">
                    <controls:ProgressDotsControl CurrentStepIndex="{Binding CurrentStepIndex}"
                                                  HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding StepDescription}"
                               FontSize="13"
                               Foreground="#DDFFFFFF"
                               HorizontalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="6" Color="#000000" Opacity="0.1" OffsetX="0" OffsetY="1"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <!-- Log area - takes remaining space -->
                <Border Grid.Row="3"
                        Background="#B0FFFFFF"
                        CornerRadius="12"
                        Padding="18,10"
                        Margin="0,0,0,6">
                    <ScrollViewer x:Name="LogScrollViewer2"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding LogEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:LogEntry">
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,3"
                                                Opacity="{Binding Opacity}">
                                        <StackPanel.Transitions>
                                            <Transitions>
                                                <DoubleTransition Property="Opacity" Duration="0:0:0.6"/>
                                            </Transitions>
                                        </StackPanel.Transitions>
                                        <TextBlock Text="{Binding Icon}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Width="18"
                                                   Foreground="{Binding IconBrush}"/>
                                        <TextBlock Text="{Binding Text}"
                                                   FontSize="14"
                                                   Foreground="#37474F"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Bottom hint + HWID -->
                <StackPanel Grid.Row="4" HorizontalAlignment="Center" Spacing="2">
                    <TextBlock Text="{Binding BottomHintText}"
                               FontSize="11"
                               Foreground="#BBFFFFFF"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding HwidText}"
                               FontSize="10"
                               FontFamily="Consolas"
                               Foreground="#66FFFFFF"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ========== SCREEN 4: COMPLETED ========== -->
        <Grid IsVisible="{Binding IsCompleted}" ClipToBounds="True">
            <controls:AnimatedGradientBackground Palette="green" />
            <controls:FloatingBubbles />
            <controls:CelebrationEffect />

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                <Grid Width="90" Height="90" HorizontalAlignment="Center">
                    <controls:GlowPulseEffect GlowColor="#4CAF50"
                                               Width="90" Height="90"/>
                    <controls:StepIconControl CurrentStep="Completed"
                                              Width="60" Height="60"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                </Grid>

                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="10" Color="#000000" Opacity="0.25" OffsetX="0" OffsetY="2"/>
                    </TextBlock.Effect>
                </TextBlock>

                <!-- Results Card -->
                <Border Background="#C0FFFFFF"
                        CornerRadius="12"
                        Padding="20,14"
                        BoxShadow="0 4 16 0 #20000000"
                        MaxWidth="400"
                        IsVisible="{Binding HasResult}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding ResultFreedSpace}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#2E7D32"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ResultPrograms}"
                                   FontSize="13"
                                   Foreground="#37474F"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ResultThreats}"
                                   FontSize="13"
                                   Foreground="#37474F"
                                   HorizontalAlignment="Center"
                                   IsVisible="{Binding HasThreatsResult}"/>
                        <TextBlock Text="{Binding ResultServices}"
                                   FontSize="13"
                                   Foreground="#37474F"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ResultStartup}"
                                   FontSize="13"
                                   Foreground="#37474F"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ResultDuration}"
                                   FontSize="12"
                                   Foreground="#78909C"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding BottomHintText}"
                           FontSize="12"
                           Foreground="#C8E6C9"
                           HorizontalAlignment="Center"/>

                <!-- ID Token -->
                <TextBlock Text="{Binding HwidText}"
                           FontSize="10"
                           FontFamily="Consolas"
                           Foreground="#80FFFFFF"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,0"/>

                <!-- CLOSE BUTTON -->
                <Button Command="{Binding CloseAppCommand}"
                        Height="42" Width="200"
                        HorizontalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        CornerRadius="10"
                        Margin="0,6,0,0">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                            <GradientStop Color="#43A047" Offset="0"/>
                            <GradientStop Color="#66BB6A" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <TextBlock Text="{Binding CloseButtonText}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="White"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ========== SCREEN 5: ERROR ========== -->
        <Grid IsVisible="{Binding HasError}" ClipToBounds="True">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#FFEBEE" Offset="0"/>
                    <GradientStop Color="#EF9A9A" Offset="0.5"/>
                    <GradientStop Color="#EF5350" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Ellipse Width="500" Height="500" Opacity="0.10"
                     Fill="White"
                     HorizontalAlignment="Right" VerticalAlignment="Center"
                     Margin="0,0,-250,0"
                     IsHitTestVisible="False"/>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
                <controls:StepIconControl CurrentStep="Error"
                                          Width="140" Height="140"/>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#B71C1C"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           MaxWidth="500"/>
                <TextBlock Text="{Binding BottomHintText}"
                           FontSize="14"
                           Foreground="#E57373"
                           HorizontalAlignment="Center"/>
                <Button Content="{Binding CloseButtonText}"
                        Command="{Binding CloseAppCommand}"
                        Height="50" Width="220"
                        FontSize="16"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>

</Window>
