<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WinOptimizer.ViewModels"
        xmlns:controls="using:WinOptimizer.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="550"
        x:Class="WinOptimizer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/winoptimizer.ico"
        Title="WinFlow Installer"
        Width="800"
        Height="550"
        CanResize="False">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- Override Fluent theme button foreground for gradient buttons -->
    <Window.Styles>
        <Style Selector="Button.accentButton /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.accentButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.accentButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>

    <Grid>
        <!-- ========== SCREEN 0: ACTIVATION ========== -->
        <Grid IsVisible="{Binding ShowActivationScreen}" ClipToBounds="True">
            <controls:AnimatedGradientBackground Palette="cyan" />
            <controls:FloatingBubbles />

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" MaxWidth="400">
                <controls:ShimmerText DisplayText="WinFlow Installer"
                                      TextSize="38"
                                      BaseColor="#006064"
                                      ShimmerColor="#4DD0E1"
                                      Width="380" Height="55"
                                      HorizontalAlignment="Center"/>

                <TextBlock Text="Activation"
                           FontSize="16"
                           Foreground="#00ACC1"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <Border Background="#C0FFFFFF"
                        CornerRadius="16"
                        Padding="28,24"
                        BoxShadow="0 4 20 0 #20000000">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Enter activation code:"
                                   FontSize="14"
                                   Foreground="#37474F"/>

                        <TextBox x:Name="ActivationCodeBox"
                                 Text="{Binding ActivationCode, Mode=TwoWay}"
                                 Watermark="00-00-00-00-00-00"
                                 MaxLength="17"
                                 FontSize="18"
                                 FontFamily="Consolas"
                                 Height="48"
                                 CornerRadius="8"
                                 LetterSpacing="2"
                                 TextChanged="ActivationCodeBox_TextChanged"/>

                        <TextBlock Text="{Binding ActivationStatus}"
                                   FontSize="13"
                                   Foreground="{Binding ActivationStatusBrush}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding HasActivationStatus}"/>

                        <Button Content="{Binding ActivateButtonText}"
                                Command="{Binding ActivateCommand}"
                                IsEnabled="{Binding CanActivate}"
                                Height="48"
                                FontSize="16"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                CornerRadius="8"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ========== SCREEN 1: LANGUAGE SELECT ========== -->
        <Grid IsVisible="{Binding ShowLanguageScreen}" Margin="30">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <TextBlock Text="WinFlow Installer"
                           FontSize="42"
                           FontWeight="Bold"
                           Foreground="#006064"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Select language / Оберіть мову / Выберите язык"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Foreground="Gray"
                           Margin="0,10,0,20"/>

                <Button Content="English"
                        Command="{Binding SelectLanguageCommand}"
                        CommandParameter="en"
                        Height="50" Width="300"
                        FontSize="16"
                        HorizontalContentAlignment="Center"/>

                <Button Content="Українська"
                        Command="{Binding SelectLanguageCommand}"
                        CommandParameter="uk"
                        Height="50" Width="300"
                        FontSize="16"
                        HorizontalContentAlignment="Center"/>

                <Button Content="Русский"
                        Command="{Binding SelectLanguageCommand}"
                        CommandParameter="ru"
                        Height="50" Width="300"
                        FontSize="16"
                        HorizontalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ========== SCREEN 2: SYSTEM ANALYSIS + 2 BUTTONS (NOT FULLSCREEN) ========== -->
        <Grid IsVisible="{Binding ShowMainScreen}" ClipToBounds="True">
            <controls:AnimatedGradientBackground Palette="deep" />
            <controls:FloatingBubbles />

            <Grid MaxWidth="700" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="4" Margin="0,0,0,16">
                    <controls:ShimmerText DisplayText="WinFlow Installer"
                                          TextSize="34"
                                          BaseColor="#B2EBF2"
                                          ShimmerColor="#FFFFFF"
                                          Width="340" Height="48"
                                          HorizontalAlignment="Center"/>

                    <TextBlock Text="{Binding SubtitleText}"
                               FontSize="15"
                               HorizontalAlignment="Center"
                               Foreground="#B2EBF2"/>
                </StackPanel>

                <!-- System Info Card -->
                <Border Grid.Row="1"
                        Background="#B0FFFFFF"
                        CornerRadius="16"
                        Padding="24,18"
                        BoxShadow="0 4 20 0 #20000000"
                        Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Hardware info -->
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="{Binding SystemInfoLabel}"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Foreground="#006064"/>

                            <TextBlock Text="{Binding SystemInfoText}"
                                       TextWrapping="Wrap"
                                       FontSize="13"
                                       Foreground="#37474F"
                                       LineHeight="20"/>

                            <TextBlock Text="{Binding CurrentOsText}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#006064"
                                       Margin="0,4,0,0"/>

                            <!-- HWID -->
                            <TextBlock Text="{Binding HwidText}"
                                       FontSize="12"
                                       FontFamily="Consolas"
                                       Foreground="#78909C"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Right: Recommendation -->
                        <Border Grid.Column="1"
                                Background="#E0F7FA"
                                CornerRadius="12"
                                Padding="18,14"
                                Margin="16,0,0,0"
                                MinWidth="200"
                                IsVisible="{Binding HasHardwareInfo}"
                                VerticalAlignment="Center">
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <TextBlock Text="&#x1F4BB;"
                                           FontSize="28"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding RecommendedWindowsText}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#004D40"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding RecommendationReason}"
                                           FontSize="11"
                                           Foreground="#4DB6AC"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           MaxWidth="180"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Status -->
                <TextBlock Grid.Row="2"
                           Text="{Binding StatusMessage}"
                           HorizontalAlignment="Center"
                           FontSize="14"
                           Foreground="#B2EBF2"
                           Margin="0,0,0,12"/>

                <!-- Two big buttons -->
                <Grid Grid.Row="3" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- AUTO INSTALL button -->
                    <Button Grid.Column="0"
                            Command="{Binding AutoInstallCommand}"
                            IsEnabled="{Binding CanStart}"
                            Height="72"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            CornerRadius="14"
                            Classes="accentButton">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                <GradientStop Color="#00897B" Offset="0"/>
                                <GradientStop Color="#00ACC1" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="&#x1F680;"
                                       FontSize="20"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding AutoInstallButtonText}"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- MANUAL INSTALL button -->
                    <Button Grid.Column="2"
                            Command="{Binding ManualInstallCommand}"
                            IsEnabled="{Binding CanStart}"
                            Height="72"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            CornerRadius="14">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                <GradientStop Color="#455A64" Offset="0"/>
                                <GradientStop Color="#607D8B" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="&#x1F527;"
                                       FontSize="20"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ManualInstallButtonText}"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Bottom hint -->
                <TextBlock Grid.Row="4"
                           Text="{Binding BottomHintText}"
                           FontSize="12"
                           Foreground="#80FFFFFF"
                           HorizontalAlignment="Center"/>
            </Grid>

            <!-- Manual version selection overlay -->
            <Border IsVisible="{Binding ShowManualSelection}"
                    Background="#E0000000"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Border Background="#F0FFFFFF"
                        CornerRadius="20"
                        Padding="36,28"
                        BoxShadow="0 8 40 0 #40000000"
                        MaxWidth="520"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel Spacing="18">
                        <TextBlock Text="{Binding ManualSelectionTitle}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#006064"
                                   HorizontalAlignment="Center"/>

                        <!-- Windows version buttons grid 2x2 -->
                        <Grid HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Windows 7 -->
                            <Button Grid.Row="0" Grid.Column="0"
                                    Command="{Binding SelectWindowsVersionCommand}"
                                    CommandParameter="7"
                                    Height="64"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    CornerRadius="12"
                                    Classes="accentButton">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                        <GradientStop Color="#1565C0" Offset="0"/>
                                        <GradientStop Color="#42A5F5" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Windows 7"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Legacy"
                                               FontSize="11"
                                               Foreground="#B0FFFFFF"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Windows 8.1 -->
                            <Button Grid.Row="0" Grid.Column="2"
                                    Command="{Binding SelectWindowsVersionCommand}"
                                    CommandParameter="8.1"
                                    Height="64"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    CornerRadius="12"
                                    Classes="accentButton">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                        <GradientStop Color="#6A1B9A" Offset="0"/>
                                        <GradientStop Color="#AB47BC" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Windows 8.1"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Legacy"
                                               FontSize="11"
                                               Foreground="#B0FFFFFF"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Windows 10 -->
                            <Button Grid.Row="2" Grid.Column="0"
                                    Command="{Binding SelectWindowsVersionCommand}"
                                    CommandParameter="10"
                                    Height="64"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    CornerRadius="12"
                                    Classes="accentButton">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                        <GradientStop Color="#00897B" Offset="0"/>
                                        <GradientStop Color="#26A69A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Windows 10"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="UEFI / GPT"
                                               FontSize="11"
                                               Foreground="#B0FFFFFF"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Windows 11 -->
                            <Button Grid.Row="2" Grid.Column="2"
                                    Command="{Binding SelectWindowsVersionCommand}"
                                    CommandParameter="11"
                                    Height="64"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    CornerRadius="12"
                                    Classes="accentButton">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                        <GradientStop Color="#0277BD" Offset="0"/>
                                        <GradientStop Color="#03A9F4" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Windows 11"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="UEFI / TPM 2.0"
                                               FontSize="11"
                                               Foreground="#B0FFFFFF"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Back button -->
                        <Button Command="{Binding ManualBackCommand}"
                                Height="40" Width="160"
                                HorizontalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                CornerRadius="10"
                                Margin="0,4,0,0">
                            <TextBlock Text="{Binding ManualBackButtonText}"
                                       FontSize="14"
                                       Foreground="#546E7A"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>

        <!-- ========== SCREEN 3: INSTALLING (FULLSCREEN) ========== -->
        <Grid IsVisible="{Binding IsOptimizing}" ClipToBounds="True">
            <controls:AnimatedGradientBackground Palette="auto" />
            <controls:FloatingBubbles />

            <Grid MaxWidth="900" HorizontalAlignment="Center" Margin="60,30,60,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <controls:ShimmerText Grid.Row="0"
                                      DisplayText="WinFlow Installer"
                                      TextSize="22"
                                      BaseColor="#80FFFFFF"
                                      ShimmerColor="#FFFFFF"
                                      Width="220" Height="34"
                                      HorizontalAlignment="Center"
                                      Margin="0,10,0,0"/>

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="12">

                    <!-- Circular progress with step icon -->
                    <Grid Width="200" Height="200" HorizontalAlignment="Center">
                        <controls:GlowPulseEffect GlowColor="#00BCD4"
                                                   Width="200" Height="200"
                                                   IsVisible="{Binding !IsCompleted}"/>
                        <!-- Circular progress ring (percentage only, no icon underneath) -->
                        <controls:CircularProgressControl Progress="{Binding ProgressPercent}"
                                                           RingThickness="10"
                                                           Width="190" Height="190"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding ShowPercentage}"/>
                        <!-- Step icon only when no percentage shown -->
                        <controls:StepIconControl CurrentStep="{Binding CurrentOptimizationStep}"
                                                  Width="130" Height="130"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  IsVisible="{Binding !ShowPercentage}"/>
                    </Grid>

                    <!-- Status text - WHITE for visibility -->
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               TextAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="12" Color="#000000" Opacity="0.3" OffsetX="0" OffsetY="2"/>
                        </TextBlock.Effect>
                        <TextBlock.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:0.4"/>
                            </Transitions>
                        </TextBlock.Transitions>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="10" Margin="0,0,0,16">
                    <controls:ProgressDotsControl CurrentStepIndex="{Binding CurrentStepIndex}"
                                                  HorizontalAlignment="Center"/>
                    <!-- Step description - WHITE -->
                    <TextBlock Text="{Binding StepDescription}"
                               FontSize="20"
                               Foreground="#DDFFFFFF"
                               HorizontalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="8" Color="#000000" Opacity="0.15" OffsetX="0" OffsetY="1"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Row="3"
                        Background="#B0FFFFFF"
                        CornerRadius="16"
                        Padding="28,14"
                        Margin="0,0,0,12"
                        MinHeight="60"
                        MaxHeight="250">
                    <ScrollViewer x:Name="LogScrollViewer"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding LogEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:LogEntry">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4"
                                                Opacity="{Binding Opacity}">
                                        <StackPanel.Transitions>
                                            <Transitions>
                                                <DoubleTransition Property="Opacity" Duration="0:0:0.6"/>
                                            </Transitions>
                                        </StackPanel.Transitions>
                                        <TextBlock Text="{Binding Icon}"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Width="24"
                                                   Foreground="{Binding IconBrush}"/>
                                        <TextBlock Text="{Binding Text}"
                                                   FontSize="20"
                                                   Foreground="#37474F"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Bottom hint - WHITE -->
                <TextBlock Grid.Row="4"
                           Text="{Binding BottomHintText}"
                           FontSize="18"
                           Foreground="#BBFFFFFF"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
            </Grid>
        </Grid>

        <!-- ========== SCREEN 4: COMPLETED ========== -->
        <Grid IsVisible="{Binding IsCompleted}" ClipToBounds="True">
            <controls:AnimatedGradientBackground Palette="green" />
            <controls:FloatingBubbles />
            <controls:CelebrationEffect />

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="28">
                <Grid Width="220" Height="220" HorizontalAlignment="Center">
                    <controls:GlowPulseEffect GlowColor="#4CAF50"
                                               Width="220" Height="220"/>
                    <controls:StepIconControl CurrentStep="Completed"
                                              Width="160" Height="160"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                </Grid>

                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="38"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="12" Color="#000000" Opacity="0.3" OffsetX="0" OffsetY="2"/>
                    </TextBlock.Effect>
                </TextBlock>

                <!-- Results Card -->
                <Border Background="#C0FFFFFF"
                        CornerRadius="16"
                        Padding="32,24"
                        BoxShadow="0 4 20 0 #20000000"
                        MaxWidth="500"
                        IsVisible="{Binding HasResult}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding ResultFreedSpace}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#2E7D32"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ResultPrograms}"
                                   FontSize="16"
                                   Foreground="#37474F"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ResultThreats}"
                                   FontSize="16"
                                   Foreground="#37474F"
                                   HorizontalAlignment="Center"
                                   IsVisible="{Binding HasThreatsResult}"/>
                        <TextBlock Text="{Binding ResultServices}"
                                   FontSize="16"
                                   Foreground="#37474F"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ResultStartup}"
                                   FontSize="16"
                                   Foreground="#37474F"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ResultDuration}"
                                   FontSize="16"
                                   Foreground="#78909C"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding BottomHintText}"
                           FontSize="16"
                           Foreground="#C8E6C9"
                           HorizontalAlignment="Center"/>

                <!-- CLOSE BUTTON -->
                <Button Command="{Binding CloseAppCommand}"
                        Height="56" Width="280"
                        HorizontalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        CornerRadius="12"
                        Margin="0,10,0,0">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                            <GradientStop Color="#43A047" Offset="0"/>
                            <GradientStop Color="#66BB6A" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <TextBlock Text="{Binding CloseButtonText}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ========== SCREEN 5: ERROR ========== -->
        <Grid IsVisible="{Binding HasError}" ClipToBounds="True">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#FFEBEE" Offset="0"/>
                    <GradientStop Color="#EF9A9A" Offset="0.5"/>
                    <GradientStop Color="#EF5350" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Ellipse Width="500" Height="500" Opacity="0.10"
                     Fill="White"
                     HorizontalAlignment="Right" VerticalAlignment="Center"
                     Margin="0,0,-250,0"
                     IsHitTestVisible="False"/>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
                <controls:StepIconControl CurrentStep="Error"
                                          Width="140" Height="140"/>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#B71C1C"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           MaxWidth="500"/>
                <TextBlock Text="{Binding BottomHintText}"
                           FontSize="14"
                           Foreground="#E57373"
                           HorizontalAlignment="Center"/>
                <Button Content="{Binding CloseButtonText}"
                        Command="{Binding CloseAppCommand}"
                        Height="50" Width="220"
                        FontSize="16"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>

</Window>
